{
  "_comment": [
    "Формат Airflow Variable 'datalab_er_wfs' (≠ схема CH-таблицы er_wf_meta).",
    "Генерируется DAG-ом export_er_sync из export.er_wf_meta FINAL.",
    "Поле 'params' — JSON-строка внутри JSON: хранится в CH как String, json.loads() при чтении."
  ],
  "evolution.lc_items_opened": {
    "replica": "hrplatform_datalab",
    "schema": "learning",
    "schedule": "55 0 * * *",
    "PK": [],
    "UK": ["person_uuid", "item_id"],
    "params": "{\"strategy\": \"FULL_UK\", \"increment\": 60, \"selfrun_timeout\": 10}",
    "fields": [
      "insert_time",
      "header_id",
      "header_person_id",
      "header_event_type",
      "header_created_dt",
      "item_id",
      "person_uuid",
      "tenant",
      "company"
    ],
    "description": "Открытые элементы обучения из Evolution",
    "sql_stmt_export_delta": {
      "from": "evolution.lc_items_opened",
      "where": "{condition}"
    }
  },
  "evolution.lc_courses_activity": {
    "replica": "hrplatform_datalab",
    "schema": "learning",
    "schedule": "*/15 * * * *",
    "PK": [],
    "UK": ["course_id", "person_uuid"],
    "params": "{\"strategy\": \"FULL_UK\", \"recent_interval\": 30, \"notify_kafka\": 0}",
    "fields": [],
    "description": "Активность по курсам (recent, скользящее окно 30 мин)",
    "sql_stmt_export_recent": {
      "from": "evolution.lc_courses_activity",
      "where": "{condition}"
    }
  }
}
